@model Platforma_pentru_tranzactii_auto.Models.Comentarii
@using Microsoft.AspNetCore.Identity
@inject UserManager<Utilizator> UserManager

<div class="card border-0 shadow-sm mb-3 fade-in-animation" id="comment-@Model.ID_Comentariu">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
            <div class="d-flex gap-3 align-items-center">

                @if (Model.User != null && Model.User.Imagine_Profil != null && Model.User.Imagine_Profil.Length > 0)
                {
                    <img src="data:image/*;base64,@(Convert.ToBase64String(Model.User.Imagine_Profil))"
                         class="rounded-circle shadow-sm"
                         style="width: 48px; height: 48px; object-fit: cover;"
                         alt="Avatar @Model.User.Nume" />
                }
                else
                {
                    <div class="rounded-circle bg-primary text-white d-flex justify-content-center align-items-center shadow-sm"
                         style="width: 48px; height: 48px; font-weight: bold; font-size: 1.2rem;">
                        @(Model.User?.Email?.Substring(0, 1).ToUpper() ?? "U")
                    </div>
                }

                <div>
                    <h6 class="mb-0 fw-bold">
                        @if (Model.User != null && !string.IsNullOrWhiteSpace(Model.User.Prenume))
                        {
                            @($"{Model.User.Prenume} {Model.User.Nume}")
                        }
                        else
                        {
                            @(Model.User?.Email ?? "Utilizator Necunoscut")
                        }
                    </h6>
                    <small class="text-muted">
                        <i class="bi bi-clock"></i> @Model.DataComentariu.ToLocalTime().ToString("dd MMM yyyy, HH:mm")
                    </small>
                </div>
            </div>

            <div class="text-end">
                <div class="text-warning mb-1">
                    @for (int i = 0; i < Model.Recenzie; i++)
                    {
                        <i class="bi bi-star-fill"></i>
                    }
                    @for (int i = Model.Recenzie; i < 5; i++)
                    {
                        <i class="bi bi-star text-muted opacity-25"></i>
                    }
                </div>

                @if (User.Identity.IsAuthenticated && Model.UserId.ToString() == UserManager.GetUserId(User))
                {
                    <form asp-action="StergeComentariu" method="post" class="delete-comment-form d-inline" data-comment-id="@Model.ID_Comentariu">
                        <input type="hidden" name="id" value="@Model.ID_Comentariu" />
                        <button type="submit" class="btn btn-link text-danger p-0 small text-decoration-none" title="Șterge acest comentariu">
                            <i class="bi bi-trash"></i> Șterge
                        </button>
                    </form>
                }
            </div>
        </div>

        <p class="mt-3 mb-0 text-dark" style="white-space: pre-line;">
            @Model.Text_Comentariu
        </p>
    </div>
</div>