@model Platforma_pentru_tranzactii_auto.Models.Contact

@{
    ViewData["Title"] = "Editare Mesaj";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <h4>Editare Mesaj / Status</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="DataTrimiterii" />

                        <div class="mb-3">
                            <label asp-for="Nume" class="form-label fw-bold">Nume</label>
                            <input asp-for="Nume" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-bold">Email</label>
                            <input asp-for="Email" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Subiect" class="form-label fw-bold">Subiect</label>
                            <input asp-for="Subiect" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Mesaj" class="form-label fw-bold">Conținut Mesaj</label>
                            <textarea asp-for="Mesaj" class="form-control" rows="5"></textarea>
                        </div>

                        <div class="form-check mb-4">
                            <input class="form-check-input" type="checkbox" asp-for="EsteCitit" />
                            <label class="form-check-label" asp-for="EsteCitit">
                                Marchează ca fiind <strong>Citit / Rezolvat</strong>
                            </label>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">Înapoi</a>
                            <button type="submit" class="btn btn-success">Salvează Modificările</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>