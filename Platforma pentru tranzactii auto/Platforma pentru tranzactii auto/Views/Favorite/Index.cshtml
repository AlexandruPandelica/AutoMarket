@model IEnumerable<Platforma_pentru_tranzactii_auto.Models.Favorite>

@{
    ViewData["Title"] = "Favoritele mele";
}

<main class="container py-5">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end mb-4 border-bottom pb-3">
        <div>
            <h1 class="fw-bold mb-1">Favoritele mele ❤️</h1>
            <p class="text-muted mb-0">Mașinile pe care le-ai salvat pentru mai târziu.</p>
        </div>
        <div class="mt-3 mt-md-0">
            <a asp-controller="Anunturi" asp-action="Index" class="btn btn-outline-primary rounded-pill px-4">
                <i class="bi bi-search"></i> Caută alte oferte
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-white shadow-sm rounded-4 border mt-4">
            <i class="bi bi-heartbreak text-muted mb-3 d-block opacity-50" style="font-size: 5rem;"></i>
            <h3 class="fw-bold">Lista ta este goală</h3>
            <p class="text-muted mb-4">Nu ai adăugat încă nicio mașină la favorite.<br /> Găsește mașina visurilor tale și salveaz-o aici!</p>
            <a asp-controller="Anunturi" asp-action="Index" class="btn btn-primary rounded-pill px-5 py-2">
                Descoperă oferte
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var fav in Model)
            {
                var item = fav.Anunt;

                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card shadow-sm h-100 border-0 overflow-hidden rounded-4 transition-hover">

                        <div class="position-relative">
                            @if (item.Imagine_Anunt != null && item.Imagine_Anunt.Length > 0)
                            {
                                <img src="data:image/*;base64,@Convert.ToBase64String(item.Imagine_Anunt)"
                                     class="card-img-top"
                                     style="height: 220px; object-fit: cover;"
                                     alt="Imagine @item.Marca @item.Model" />
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center bg-light text-muted"
                                     style="height: 220px;">
                                    <i class="bi bi-camera-fill me-2 fs-3"></i>
                                </div>
                            }

                            <span class="position-absolute bottom-0 start-0 m-3 badge bg-primary fs-6 shadow">
                                @item.Pret.ToString("N0") €
                            </span>

                            <form asp-controller="Favorite"
                                  asp-action="Toggle"
                                  method="post"
                                  class="position-absolute top-0 end-0 m-3">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="anuntId" value="@item.ID_Anunt" />
                                <button type="submit" class="btn btn-light rounded-circle shadow-sm p-2 d-flex align-items-center justify-content-center"
                                        style="width: 38px; height: 38px; border: none;"
                                        title="Șterge din favorite">
                                    <i class="bi bi-heart-fill text-danger fs-5"></i>
                                </button>
                            </form>
                        </div>

                        <div class="card-body pb-2">
                            <h5 class="card-title fw-bold mb-2">
                                @item.Marca @item.Model
                            </h5>

                            <div class="d-flex flex-wrap gap-2 text-muted small mb-2">
                                <span><i class="bi bi-calendar"></i> @item.An_Fabricatie</span>
                                <span><i class="bi bi-speedometer2"></i> @item.Kilometraj.ToString("N0") km</span>
                                @if (!string.IsNullOrEmpty(item.Combustibil))
                                {
                                    <span><i class="bi bi-fuel-pump"></i> @item.Combustibil</span>
                                }
                                @if (item.PutereCP > 0)
                                {
                                    <span><i class="bi bi-lightning-charge"></i> @item.PutereCP CP</span>
                                }
                            </div>
                        </div>

                        <div class="card-footer bg-white border-0 pt-0 pb-4 px-4">
                            <a asp-controller="Anunturi"
                               asp-action="Details"
                               asp-route-id="@item.ID_Anunt"
                               class="btn btn-outline-primary w-100 rounded-pill">
                                Vezi Detalii complete
                            </a>
                        </div>

                    </div>
                </div>
            }
        </div>
    }
</main>

<style>
    /* Efect subtil de ridicare a cardului când pui mouse-ul pe el */
    .transition-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .transition-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
        }
</style>