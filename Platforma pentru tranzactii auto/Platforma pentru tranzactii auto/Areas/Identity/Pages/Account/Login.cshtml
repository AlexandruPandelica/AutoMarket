@page
@model LoginModel
@{
    ViewData["Title"] = "Autentificare";
}

<style>
    /* 1. Nu mai stilizăm 'body', ci folosim această clasă wrapper */
    .login-wrapper {
        background: linear-gradient(135deg, #0d6efd 0%, #003b99 100%);
        /* Ocupă tot ecranul, minus aprox 60px cât are navbar-ul, ca să nu apară scroll inutil */
        min-height: calc(100vh - 60px);
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        /* Ne asigurăm că fundalul se întinde pe toată lățimea, anulând marginile containerului standard */
        margin-top: -1.5rem; /* Ajustare fină pentru a lipi fundalul de navbar */
        padding-top: 2rem;
        padding-bottom: 2rem;
    }

    /* Dacă layout-ul tău are un container care limitează lățimea, trebuie să "spargem" containerul */
    /* Aceasta este o tehnică de a face un div full-width chiar dacă e într-un container */
    .full-width-breakout {
        width: 100vw;
        position: relative;
        left: 50%;
        right: 50%;
        margin-left: -50vw;
        margin-right: -50vw;
    }

    .login-card {
        background: white;
        border-radius: 18px;
        padding: 35px 40px;
        width: 100%;
        max-width: 450px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        animation: fadeIn 0.5s ease-in-out;
    }

    @@keyframes fadeIn {
        from

    {
        opacity: 0;
        transform: translateY(20px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .login-icon {
        width: 80px;
        margin-bottom: 15px;
    }

    .btn-primary-custom {
        background-color: #0d6efd;
        border: none;
        border-radius: 50px;
        padding: 12px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-primary-custom:hover {
            background-color: #003b99;
            transform: scale(1.02);
        }
</style>

<div class="full-width-breakout">
    <div class="login-wrapper">
        <div class="login-card">

            <div class="text-center">
                <img class="login-icon" src="https://cdn-icons-png.flaticon.com/512/847/847969.png" alt="Login Icon" />
            </div>

            <h3 class="text-center mb-4 fw-bold text-dark">Logare în cont</h3>

            <form id="account" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" placeholder="nume@email.com" />
                    <label asp-for="Input.Email" class="text-secondary">Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" type="password" class="form-control" placeholder="Parolă" />
                    <label asp-for="Input.Password" class="text-secondary">Parolă</label>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="form-check mb-4">
                    <input asp-for="Input.RememberMe" class="form-check-input" />
                    <label asp-for="Input.RememberMe" class="form-check-label text-muted small">Ține-mă minte</label>
                </div>

                <button type="submit" class="btn btn-primary btn-primary-custom w-100 mb-3">Autentificare</button>

                <div class="text-center d-flex flex-column gap-2">
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none small">
                        Nu ai cont? <span class="fw-bold">Creează unul nou</span>
                    </a>
                    <a asp-page="./ForgotPassword" class="text-decoration-none text-muted small">Ai uitat parola?</a>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}